# PRISM contracts deploy env — copy to `.env` (gitignored) and fill in.
# Used by:
#   - `forge script packages/contracts/script/Deploy.s.sol:Deploy ...`
#   - `pnpm post-deploy --chain base-sepolia` (parses Foundry broadcast)
#   - `pnpm verify-hook --chain base-sepolia`
#
# See `docs/deploy-runbook.md` for the full deploy procedure.

# =============================================================================
# RPC endpoints
# =============================================================================
# Where to send the deploy txs. Free public endpoints work but get
# throttled — for a real broadcast use a paid RPC (Alchemy / Infura /
# QuickNode / Tenderly).
#   - https://www.alchemy.com/        (free tier covers Base Sepolia)
#   - https://www.infura.io/
#   - https://dashboard.tenderly.co/  (also gives you the alert dashboard
#                                      you'll wire up later — see
#                                      docs/monitoring.md)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# =============================================================================
# Block-explorer verification
# =============================================================================
# Used by `forge script --verify`. ONE key works for both Base and Base
# Sepolia. Get from:
#   https://basescan.org/myapikey
# (Sign up with email, free tier is fine for verification.)
BASESCAN_API_KEY=

# =============================================================================
# Deployer
# =============================================================================
# Hex-prefixed private key of the EOA that broadcasts the deploy txs.
# Must hold enough native ETH on the target chain to cover gas (a few
# tenths of an ETH on Sepolia is plenty; on Base mainnet target ~$50).
#
# How to generate:
#   cast wallet new
# This prints a fresh address + private key. Send testnet ETH to that
# address from the Base Sepolia faucet:
#   https://docs.base.org/docs/tools/network-faucets
#
# **NEVER reuse a key with mainnet funds. NEVER commit this value.**
DEPLOYER_PRIVATE_KEY=

# =============================================================================
# Owner / governance
# =============================================================================
# Address that becomes the owner of every vault VaultFactory deploys.
# This account can pause `deposit` (but never `withdraw` — invariant 6)
# and trigger emergency operations.
#
# **For mainnet this MUST be a multisig (Safe / Squads / similar).**
# For Sepolia you can use a fresh EOA you control while testing.
#
# Create a Safe:
#   https://app.safe.global/   (deploy a Safe on Base Sepolia, copy the
#                               Safe address — not any of the signer EOAs)
DEFAULT_OWNER=

# =============================================================================
# V4 PoolManager
# =============================================================================
# Canonical Uniswap V4 PoolManager singleton on the target chain. Has
# the same address across every chain V4 has launched on, but verify
# against the official Uniswap docs before broadcast:
#   https://docs.uniswap.org/contracts/v4/deployments
#
# As of v4 launch: the PoolManager address is published in the Uniswap
# docs and on the v4-core repo's `deployments.json`. Paste the
# Base Sepolia entry here.
POOL_MANAGER=

# =============================================================================
# Chainlink price feed
# =============================================================================
# Address of the Chainlink AggregatorV3 feed for the pool's price
# pair. For an ETH/USDC vault on Base Sepolia, use the ETH / USD feed.
#
# Find the right feed at:
#   https://docs.chain.link/data-feeds/price-feeds/addresses?network=base&page=1
#   (filter "Base Sepolia")
# Common Base Sepolia feeds:
#   - ETH / USD
#   - BTC / USD
#   - LINK / USD
# Click into the feed page and copy the "Contract address".
CHAINLINK_FEED=

# =============================================================================
# Sequencer uptime feed
# =============================================================================
# L2 sequencer uptime feed. PRISM checks this before trusting the
# Chainlink price — if the sequencer is down, the price may be stale.
#
# Get from the same Chainlink page as above ("L2 Sequencer Uptime"
# section). Each L2 has its own; for Base it's a single sequencer feed.
#   https://docs.chain.link/data-feeds/l2-sequencer-feeds
SEQUENCER_FEED=

# =============================================================================
# Price scale (Q192)
# =============================================================================
# These two numbers convert the Chainlink price (8 decimals, integer)
# into Uniswap V4's sqrtPriceX96 scale (Q64.96, then squared into Q192
# during the read). They are pool-specific because they depend on the
# token decimals on each side of the pool.
#
# Compute off-chain. For an `tokenIn / tokenOut` pool with decimals
# `d_in` and `d_out`:
#
#   PRICE_SCALE_NUM = 10**(d_in + chainlink_feed_decimals)
#   PRICE_SCALE_DEN = 10**(d_out)
#
# Example: ETH / USDC where ETH has 18 dec, USDC has 6 dec, the
# ETH/USD feed has 8 dec:
#   PRICE_SCALE_NUM = 10**(18 + 8) = 10**26 = 100000000000000000000000000
#   PRICE_SCALE_DEN = 10**(6)      = 10**6  = 1000000
#
# Helper script (run from packages/contracts):
#   forge script script/util/PrintScale.s.sol \
#     --sig "run(uint8,uint8,uint8)" <d_in> <d_out> <feed_decimals>
# (writes the two values to stdout — TODO: ship this helper if you'll
# deploy more than one pool).
PRICE_SCALE_NUM=
PRICE_SCALE_DEN=

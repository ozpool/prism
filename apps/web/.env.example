# WalletConnect Cloud project ID — sign up at https://cloud.walletconnect.com.
# Required at runtime; the build will succeed with a placeholder so CI
# smoke tests pass, but production deployments MUST set this.
NEXT_PUBLIC_WC_PROJECT_ID=

# Optional: custom Base Sepolia RPC. Defaults to viem's public endpoint
# when unset; expect rate limits on burst usage.
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=

# Optional: Sentry DSN for browser-side error capture. When unset,
# init is a no-op (local dev / preview).
NEXT_PUBLIC_SENTRY_DSN=

# Optional: Sentry DSN for server-side (Node + Edge) capture inside
# route handlers and middleware. Usually the same project as the
# client DSN.
SENTRY_DSN=

# Optional: Sentry environment + release tags surfaced in the UI.
NEXT_PUBLIC_SENTRY_ENV=
NEXT_PUBLIC_SENTRY_RELEASE=
SENTRY_ENV=
SENTRY_RELEASE=

# Optional: build-time-only — required to upload source maps from the
# Next.js build to Sentry. Without it, withSentryConfig still wraps
# the build but skips upload.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

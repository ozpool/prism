# WalletConnect Cloud project ID — sign up at https://cloud.walletconnect.com.
# Required at runtime; the build will succeed with a placeholder so CI
# smoke tests pass, but production deployments MUST set this.
NEXT_PUBLIC_WC_PROJECT_ID=

# Optional: custom Base Sepolia RPC. Defaults to viem's public endpoint
# when unset; expect rate limits on burst usage.
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=
